{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls*)",
      "Bash(pwd*)",
      "Bash(tree*)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git blame*)",
      "Bash(git stash list*)",
      "Bash(git remote -v*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git worktree list*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run format*)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm build*)",
      "Bash(pnpm format*)",
      "Bash(pnpm list*)",
      "Bash(bun test*)",
      "Bash(bun run test*)",
      "Bash(bun run lint*)",
      "Bash(bun run dev*)",
      "Bash(bun run build*)",
      "Bash(tsc*)",
      "Bash(pytest*)",
      "Bash(ruff check*)",
      "Bash(ruff format --check*)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff*)",
      "Bash(uv pip list*)",
      "Bash(uv pip show*)",
      "Bash(uv sync*)",
      "Bash(uv lock*)",
      "Bash(pyright*)",
      "Bash(mypy*)",
      "Bash(supabase status*)",
      "Bash(supabase db diff*)",
      "Bash(supabase gen types*)",
      "Bash(supabase migration list*)",
      "Bash(supabase migration new*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh api*)",
      "Bash(next dev*)",
      "Bash(next build*)",
      "Bash(vite*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf --no-preserve-root*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(git cherry-pick*)",
      "Bash(git checkout --*)",
      "Bash(git clean*)",
      "Bash(git branch -D*)",
      "Bash(git commit --amend*)",
      "Bash(supabase db push*)",
      "Bash(supabase db reset*)",
      "Bash(supabase migration apply*)",
      "Bash(supabase migration repair*)",
      "Bash(supabase link*)",
      "Bash(supabase functions deploy*)",
      "Bash(supabase secrets*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(uv publish*)",
      "Bash(uv add*)",
      "Bash(uv remove*)",
      "Bash(npm install*)",
      "Bash(npm uninstall*)",
      "Bash(pnpm add*)",
      "Bash(pnpm remove*)",
      "Bash(pnpm install*)",
      "Bash(bun add*)",
      "Bash(bun remove*)",
      "Bash(bun install*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/reflect-nudge.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/workflow-dispatcher.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/no-commit-on-master.sh",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "autoMode": {
    "allow": [
      "Read-only file inspection (cat, ls, tree, file, head, tail, wc, find with no -delete/-exec) is always safe.",
      "Type checkers (tsc, pyright, mypy), linters (ruff check, eslint), and formatters in check-only mode are safe.",
      "Test runs (pytest, npm test, bun test, vitest, jest, playwright) are safe unless they spawn production services.",
      "Git inspection (status, diff, log, show, blame, branch listing, rev-parse, worktree list) is safe.",
      "Dev servers and builds (next dev, next build, vite, uv run, npm run dev/build) are safe.",
      "Supabase read-only operations (status, db diff for inspection, gen types, migration list) are safe.",
      "GitHub CLI read operations (gh pr view/list/diff, gh issue view/list, gh run view/list, gh api GET) are safe."
    ],
    "soft_deny": [
      "Database writes, updates, deletes, migrations, or schema changes require user approval. This covers: psql/mysql/sqlite invocations with INSERT/UPDATE/DELETE/DROP/ALTER/TRUNCATE/CREATE/GRANT, supabase migration apply/push/reset/repair, Prisma migrate deploy/reset, Drizzle push, Alembic upgrade/downgrade, TypeORM migration:run. Reading (SELECT, describe, status, schema inspection) is fine.",
      "Package installations, removals, or version changes require approval. npm/pnpm/bun add/install/remove/uninstall, uv add/remove/sync that changes the lockfile, pip install/uninstall. Reading package state (list, show) is fine.",
      "Any command bypassing safety features (--no-verify, --force, --no-gpg-sign, --skip-checks, --allow-empty-message) requires approval, even if the underlying command would otherwise be safe.",
      "Destructive git operations (reset --hard, clean -f, branch -D, checkout --, rebase on shared branches, commit --amend on pushed commits, force push) require approval. Inspection (status/diff/log/show/blame) is fine.",
      "Network-modifying operations (deployments, pushes to remote infra, API writes, infra-as-code apply, supabase functions deploy) require approval. Read-only API calls and inspection commands are fine.",
      "Commands that delete or rename many files (rm -r on non-trivial paths, find with -delete/-exec rm, xargs rm) require approval, regardless of path.",
      "Writing or editing files outside the project root (home directory dotfiles, /etc, system paths) requires approval."
    ]
  },
  "skipAutoPermissionPrompt": true
}
